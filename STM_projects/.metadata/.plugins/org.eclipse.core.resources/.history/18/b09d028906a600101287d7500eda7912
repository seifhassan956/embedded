/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_USART1_UART_Init();
  /* USER CODE BEGIN 2 */

  char x[] = "Enter case number (1-5): ";
  uint8_t rx_uart;
  uint16_t case_id;
  uint8_t tx_id[2];
  uint8_t rx_data[3];
  uint8_t dummy_tx[3] = {0xFF, 0xFF, 0xFF};
  char outmsg[80];

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    HAL_UART_Transmit(&huart1, (uint8_t *)x, strlen(x), HAL_MAX_DELAY);

    // Read input from UART
    HAL_UART_Receive(&huart1, (uint8_t *)&rx_uart, 1, HAL_MAX_DELAY);

    if (rx_uart < '1' || rx_uart > '5')
    {
      char err[] = "Invalid input. Enter 1..5\r\n";
      HAL_UART_Transmit(&huart1, (uint8_t *)err, strlen(err), HAL_MAX_DELAY);
      HAL_Delay(50);
      continue;
    }

    case_id = 0x1000 + (rx_uart - '0');
    HAL_UART_Transmit(&huart1, (uint8_t *)"\r\n", 2, HAL_MAX_DELAY);

    tx_id[0] = (case_id >> 8) & 0xFF;
    tx_id[1] = case_id & 0xFF;

    // Send Case ID
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_RESET);
    HAL_SPI_Transmit(&hspi1, tx_id, 2, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_SET);

    // Read encoded response
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_RESET);
    HAL_SPI_TransmitReceive(&hspi1, dummy_tx, rx_data, 3, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_SET);

    // Decode
    uint32_t encoded = ((uint32_t)rx_data[0] << 16) |
                       ((uint32_t)rx_data[1] << 8) |
                       (uint32_t)rx_data[2];

    float voltage = (float)(encoded >> 12) / 10.0f;

    uint16_t speed = (uint16_t)(encoded & 0x0FFF);

    int len = snprintf(outmsg, sizeof(outmsg),
                       "Case 0x%04X => Voltage: %.1f V, Speed: %d RPM\r\n",
                       case_id, voltage, speed);
    HAL_UART_Transmit(&huart1, (uint8_t *)outmsg, len, HAL_MAX_DELAY);

    HAL_Delay(50);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

